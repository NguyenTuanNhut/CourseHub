              "raw": "{\n  \"username\": \"student01\",\n  \"email\": \"student01@example.com\",\n  \"password\": \"Password@123\",\n  \"confirmPassword\": \"Password@123\",\n  \"fullName\": \"Student One\",\n  \"phone\": \"0900000000\"\n}"
